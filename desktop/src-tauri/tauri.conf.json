{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop AI Pet",
  "version": "0.1.0",
  "identifier": "com.example.desktopaipet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop AI Pet",
        "width": 420,
        "height": 680,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
